# ⚠️ このファイルはテンプレートです。実運用ではコピーして `secrets.toml` を作り、
#    Streamlit Community Cloud にデプロイする場合は「Advanced settings → Secrets」に
#    以下の内容を貼り付けてください（GitHub にはコミット禁止）。

# ──────────────────────────────────
# ブランド設定
# ──────────────────────────────────
[brand]
# ダッシュボードのタイトル・ページタイトルに使う名前
# 例: "hajuCS" → 「hajuCSダッシュボード」
name = "Co-HeartCS"

# ──────────────────────────────────
# データソース（Google スプレッドシートの公開 URL）
# キーはコールセンター区分（例: LU, N2 など）
# 値は "/pub" までのベース URL（"/pub?output=csv" は不要）
# ──────────────────────────────────
[sheets]
LU = "https://docs.google.com/spreadsheets/d/e/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
N2 = "https://docs.google.com/spreadsheets/d/e/yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# ──────────────────────────────────
# パスワード保護（任意・現状未使用）
# ──────────────────────────────────
# [auth]
# password = "your-strong-password"
